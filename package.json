{
  "name": "bambu-history-dump",
  "version": "1.0.0",
  "description": "Sync Bambu Lab print history to SQLite with pricing, projects, and a lightweight dashboard.",
  "main": "dump-bambu-history.ts",
  "scripts": {
    "sync": "npx tsx sync-configured-providers.ts",
    "sync:bambu": "npx tsx dump-bambu-history.ts",
    "sync:moonraker": "npx tsx sync-moonraker-history.ts",
    "catalog": "npx tsx scan-catalog.ts",
    "normalize": "npx tsx normalize.ts",
    "baseline": "npx tsx scripts/baseline-report.ts",
    "api": "npx tsx api.ts",
    "dev": "concurrently --kill-others --names api,ui \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "npx tsx watch api.ts",
    "dev:full": "npm run dev",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "build": "npm run build:ui && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.backend.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.ts\" \"**/*.json\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.ts\" \"**/*.json\" --ignore-path .gitignore"
  },
  "keywords": [],
  "author": "Adam",
  "license": "ISC",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.4.2",
    "hono": "^4.12.1",
    "htm": "^3.1.1",
    "preact": "^10.29.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "concurrently": "^10.0.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.3.5",
    "vitest": "^4.0.18"
  }
}
