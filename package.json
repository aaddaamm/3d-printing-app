  "main": "dump-bambu-history.ts",
  "scripts": {
    "sync": "npx tsx dump-bambu-history.ts",
    "normalize": "npx tsx normalize.ts",
    "api": "npx tsx api.ts",
    "dev": "npx tsx watch api.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
